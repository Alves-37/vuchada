{
  "version": 2,
  "builds": [
    {
      "src": "static/**",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://neoerp-production.up.railway.app/api/$1"
    },
    {
      "src": "/public/(.*)",
      "dest": "https://neoerp-production.up.railway.app/public/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "https://neoerp-production.up.railway.app/uploads/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/$",
      "dest": "/static/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/static/$1"
    }
  ]
}
